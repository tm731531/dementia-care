# Companion Call configuration — copy this to .env and fill real values
# .env is gitignored, .env.example IS committed (no secrets, only structure)

# ===== Twilio =====
TWILIO_ACCOUNT_SID=AC_replace_with_yours
TWILIO_AUTH_TOKEN=replace_with_yours
TWILIO_FROM_NUMBER=+1XXXXXXXXXX

# ===== 媽媽端電話（Phase 1 = Tom 自己手機，Phase 2 = 媽媽 SIM）=====
MOM_PHONE_NUMBER=+886XXXXXXXXX

# ===== Twilio Functions URL（部署後 twilio CLI 印出的）=====
# 範例: https://companion-call-1234-dev.twil.io
# 取得方式: cd companion_call/twilio_functions/ && twilio serverless:deploy
TWILIO_FUNCTIONS_BASE_URL=https://your-deploy.twil.io

# ===== iDempiere（命名跟既有 OCR config.py 對齊）=====
IDEMPIERE_URL=http://192.168.0.93:8080/api/v1
IDEMPIERE_USER=YOUR_USER
IDEMPIERE_PASS=YOUR_PASSWORD
IDEMPIERE_CLIENT_ID=1000000
IDEMPIERE_ROLE_ID=1000000
IDEMPIERE_ORG_ID=0
IDEMPIERE_WAREHOUSE_ID=0

# Patient/record defaults — same conventions as OCR config.py
PATIENT_NAME=YOUR_PATIENT_NAME
REPORTER_BPARTNER_ID=1000000
TARGET_TABLE=z_momsystem

# ===== 全域行為 =====
COMPANION_CALL_DURATION_SEC=90
COMPANION_CALL_END_TRIGGER_SEC=80
LOG_LEVEL=INFO
